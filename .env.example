CHONGBULUO_USERNAME=你的用户名
CHONGBULUO_PASSWORD=你的密码

# 登录页（默认可不改）
LOGIN_URL=https://www.chongbuluo.com/member.php?mod=logging&action=login

# 打卡入口页（请按你的账号实际页面调整）
CHECKIN_URL=https://www.chongbuluo.com

# 下面是页面元素选择器，首次运行失败时按实际页面调整
USERNAME_SELECTOR=input[name='username']
PASSWORD_SELECTOR=input[name='password']
SUBMIT_SELECTOR=button[type='submit'], input[type='submit']

# 签到按钮可能有多种写法，按需增删
CHECKIN_SELECTOR=a[href*='qiandao'], a[href*='sign'], button:has-text('签到'), a:has-text('签到')

# 是否无头模式：true/false
HEADLESS=true
